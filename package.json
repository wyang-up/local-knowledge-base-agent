{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n frontend,backend -c blue,green \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=150 vite --config frontend/config/vite.config.ts --host 0.0.0.0 --port 5173",
    "dev:backend": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=150 npm run dev --prefix backend",
    "build": "vite build --config frontend/config/vite.config.ts",
    "preview": "vite preview --config frontend/config/vite.config.ts",
    "clean": "rm -rf dist",
    "lint": "npm run lint:frontend && npm run lint:backend",
    "lint:frontend": "tsc --noEmit",
    "lint:backend": "npm run lint --prefix backend",
    "test": "vitest run --config frontend/config/vitest.config.ts",
    "test:frontend:stable": "vitest run --config frontend/config/vitest.config.ts --pool threads --maxWorkers 1 --no-isolate",
    "test:backend": "vitest run --config vitest.config.ts backend/pipeline/document-delete.test.ts backend/pipeline/document-pipeline-store.test.ts backend/pipeline/document-artifact-store.test.ts",
    "test:regression": "npm run test:backend && npm run test:frontend:stable -- frontend/src/pages/app/components/preview/renderers/preview-renderers.test.tsx frontend/src/pages/app/components/preview/DocumentPreviewContent.test.tsx frontend/src/pages/app/components/DocumentListPanel.test.tsx frontend/src/pages/app/components/DocumentDetailPanel.test.tsx frontend/src/pages/app/App.test.tsx"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@lancedb/lancedb": "^0.27.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.2"
  }
}
