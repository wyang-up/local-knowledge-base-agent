{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "strict": false,
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "noEmit": true
  },
  "include": ["*.ts", "config/*.ts", "pipeline/*.ts", "settings/*.ts", "storage/*.ts", "utils/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "**/__generated__/**",
    "**/*.generated.ts"
  ]
}
